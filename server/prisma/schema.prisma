generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id             Int      @id @default(autoincrement())
  name           String
  logo           String?
  industry       String?
  contactNumber  String?
  description    String?
  streetAddress  String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  isoStandards   String[] @default([])
  location       String?
  contactDetails String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         Int?
  user           User?    @relation("UserCompanies", fields: [userId], references: [id])
  sites          Site[]
  @@index([userId])
}

model Site {
  id              Int            @id @default(autoincrement())
  name            String
  description     String?
  siteType        String?
  status          String?        @default("Active")
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  latitude        Float?
  longitude       Float?
  contactName     String?
  contactPosition String?
  contactNumber   String?
  email           String?
  companyId       Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          Int?
  auditPrograms   AuditProgram[]
  departments     Department[]
  company         Company        @relation(fields: [companyId], references: [id])
  user            User?          @relation("UserSites", fields: [userId], references: [id])
  @@index([userId])
  @@index([companyId])
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  siteId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  code        String?
  manager     String?
  status      String?  @default("Active")
  site        Site     @relation(fields: [siteId], references: [id])
}

model User {
  id                Int            @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String         @unique
  mobile            String?
  role              String
  customRoleName    String?
  password          String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  isActive          Boolean        @default(true)
  creatorId         Int?

  // Subscription and Trial fields
  trialStartDate    DateTime?
  trialEndDate      DateTime?
  subscriptionStatus String?
  subscriptionPlan   String?
  planStartDate      DateTime?
  planExpiryDate     DateTime?
  nextBillingDate    DateTime?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  stripePriceId      String?
  stripeInvoiceId    String?
  stripePaymentIntentId String?

  // Renewal preferences
  renewalType       String?    // 'AUTOPAY' or 'MANUAL'
  autopayConsent    Boolean?   @default(false)

  // Team/Audit relations
  leadAuditPlans    AuditPlan[]    @relation("PlanLeadAuditor")
  createdPlans      AuditPlan[]    @relation("UserAuditPlans")
  leadAuditPrograms AuditProgram[] @relation("LeadAuditor")
  createdPrograms   AuditProgram[] @relation("UserAuditPrograms")
  onboardingCompleted Boolean    @default(false)
  companies         Company[]      @relation("UserCompanies")
  sites             Site[]         @relation("UserSites")
  creator           User?          @relation("UserCreator", fields: [creatorId], references: [id])
  createdUsers      User[]         @relation("UserCreator")
  auditPrograms     AuditProgram[] @relation("AuditorPrograms")
  auditPlans        AuditPlan[]    @relation("PlanAuditors")

  // Payment relations
  subscriptions     Subscription[]
  payments          Payment[]
}

model Subscription {
  id                   Int       @id @default(autoincrement())
  userId               Int
  stripeSubscriptionId String    @unique
  plan                 String
  status               String    // active, past_due, canceled, unpaid
  cancelAtPeriodEnd    Boolean   @default(false)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  stripePriceId        String
  sub_renewal_date     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])
}

model Payment {
  id                   Int       @id @default(autoincrement())
  userId               Int
  amount               Float
  currency             String
  status               String
  stripePaymentIntentId String?  @unique
  stripeInvoiceId      String?   @unique
  stripeSessionId      String?   @unique
  billingType          String    // monthly, yearly, contract
  duration             String?   // 1year, 3years, 6years
  createdAt            DateTime  @default(now())
  user                 User      @relation(fields: [userId], references: [id])
}

model WebhookEvent {
  id               String   @id // Stripe Event ID
  type             String
  processed        Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model AuditProgram {
  id            Int         @id @default(autoincrement())
  name          String
  isoStandard   String
  frequency     String
  duration      Int         @default(3)
  siteId        Int
  scheduleData  Json?
  status        String      @default("Draft")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  leadAuditorId Int?
  userId        Int?
  auditPlans    AuditPlan[]
  leadAuditor   User?       @relation("LeadAuditor", fields: [leadAuditorId], references: [id])
  site          Site        @relation(fields: [siteId], references: [id])
  user          User?       @relation("UserAuditPrograms", fields: [userId], references: [id])
  auditors      User[]      @relation("AuditorPrograms")
  @@index([userId])
  @@index([siteId])
}

model AuditPlan {
  id             Int          @id @default(autoincrement())
  auditProgramId Int
  executionId    String
  auditType      String?
  date           DateTime?
  location       String?
  scope          String?
  objective      String?
  criteria       String?
  leadAuditorId  Int?
  itinerary      Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  auditName      String?
  templateId     String?
  auditData      Json?
  userId         Int?
  findingsData   Json?
  auditProgram   AuditProgram @relation(fields: [auditProgramId], references: [id])
  leadAuditor    User?        @relation("PlanLeadAuditor", fields: [leadAuditorId], references: [id])
  user           User?        @relation("UserAuditPlans", fields: [userId], references: [id])
  auditors       User[]       @relation("PlanAuditors")

  @@unique([auditProgramId, executionId])
  @@index([userId])
  @@index([auditProgramId])
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
